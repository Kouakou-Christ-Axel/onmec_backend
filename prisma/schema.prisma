generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  moduleFormat    = "cjs"
  runtime         = "nodejs"
  previewFeatures = ["fullTextSearchPostgres", "relationJoins"]
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  MEMBER
}

model User {
  id       String  @id @default(uuid()) @db.Uuid
  fullname String  @db.VarChar
  email    String  @unique @db.VarChar
  phone    String? @db.VarChar
  password String  @db.VarChar

  role UserRole @default(MEMBER)

  emailVerified Boolean @default(false)
  otpSecret     String? @db.VarChar

  // Avatar (chemin/URL de la photo de profil, optionnel)
  avatar String? @db.VarChar

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  Document           Document[]
  SignalementCitoyen SignalementCitoyen[]
  Notification       Notification[]
  DeviceToken        DeviceToken[]
  UserQuiz           UserQuiz[]
  Quiz               Quiz[]               @relation("QuizAuthor")
  Reaction           Reaction[]
  Commentaire        Commentaire[]
  UserGamification   UserGamification?
  PointTransaction   PointTransaction[]

  @@map("users")
}

model Document {
  id           String   @id @default(uuid())
  title        String
  description  String?
  categorie    String? // catégorie libre du document (filtrage côté app)
  coverImage   String? // chemin local ou URL vers l'image de couverture
  fileUrl      String // chemin local ou URL vers le fichier uploadé
  fileType     String // ex: "pdf", "docx", "epub"
  uploadedAt   DateTime @default(now())
  uploadedBy   User?    @relation(fields: [uploadedById], references: [id])
  uploadedById String?  @db.Uuid
}

enum StatutSignalement {
  NOUVEAU
  EN_COURS
  RESOLU
  REJETE
}

model CategorieSignalement {
  id                    String  @id @default(uuid()) @db.Uuid
  nom                   String  @db.VarChar
  description           String? @db.Text
  validationObligatoire Boolean @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  signalements SignalementCitoyen[]

  @@map("categories_signalement")
}

model SignalementCitoyen {
  id          String @id @default(uuid()) @db.Uuid
  titre       String @db.VarChar
  description String @db.Text

  categorieId String               @db.Uuid
  categorie   CategorieSignalement @relation(fields: [categorieId], references: [id])
  validation  Boolean              @default(false)

  adresse   String  @db.VarChar(255)
  latitude  Decimal @db.Decimal(10, 7)
  longitude Decimal @db.Decimal(10, 7)

  photo String? @db.VarChar

  statut StatutSignalement @default(NOUVEAU)

  citoyenId String? @db.Uuid
  citoyen   User?   @relation(fields: [citoyenId], references: [id])

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  reactions    Reaction[]
  commentaires Commentaire[]

  @@map("signalements_citoyens")
}

enum QuizDifficulte {
  FACILE
  MOYEN
  DIFFICILE
}

model CategorieQuiz {
  id          String  @id @default(uuid()) @db.Uuid
  nom         String  @db.VarChar
  description String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  quizzes Quiz[]

  @@map("categories_quiz")
}

// Quiz créés par les utilisateurs
model Quiz {
  id          String          @id @default(uuid()) @db.Uuid
  title       String
  description String?
  difficulte  QuizDifficulte?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  authorId    String         @db.Uuid
  author      User           @relation("QuizAuthor", fields: [authorId], references: [id])
  categorieId String?        @db.Uuid
  categorie   CategorieQuiz? @relation(fields: [categorieId], references: [id])

  questions   Question[]
  userQuizzes UserQuiz[]
}

// Questions pour chaque quiz
model Question {
  id        String   @id @default(uuid()) @db.Uuid
  text      String
  quizId    String   @db.Uuid
  quiz      Quiz     @relation(fields: [quizId], references: [id])
  choices   Choice[]
  correctId String?  @db.Uuid

  UserAnswer UserAnswer[]
}

// Choix possibles pour chaque question
model Choice {
  id         String   @id @default(uuid()) @db.Uuid
  text       String
  questionId String   @db.Uuid
  question   Question @relation(fields: [questionId], references: [id])

  UserAnswer UserAnswer[]
}

// Table intermediaire pour les résultats des quiz par utilisateur
model UserQuiz {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @db.Uuid
  quizId      String    @db.Uuid
  score       Int
  completedAt DateTime?

  user    User         @relation(fields: [userId], references: [id])
  quiz    Quiz         @relation(fields: [quizId], references: [id])
  answers UserAnswer[]
}

// Table intermediaire pour les réponses des utilisateurs aux questions
model UserAnswer {
  id         String @id @default(uuid()) @db.Uuid
  userQuizId String @db.Uuid
  questionId String @db.Uuid
  choiceId   String @db.Uuid

  userQuiz UserQuiz @relation(fields: [userQuizId], references: [id])
  question Question @relation(fields: [questionId], references: [id])
  choice   Choice   @relation(fields: [choiceId], references: [id])
}

// Notifications pour les utilisateurs
model Notification {
  id        String   @id @default(uuid()) @db.Uuid
  title     String
  body      String
  type      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id])
}

// Tokens de périphériques pour les notifications push
model DeviceToken {
  id        String   @id @default(uuid()) @db.Uuid
  token     String   @unique
  platform  String?
  createdAt DateTime @default(now())

  userId String? @db.Uuid
  user   User?   @relation(fields: [userId], references: [id])
}

model Actualite {
  id        String   @id @default(uuid()) @db.Uuid
  slug      String   @unique
  title     String
  date      DateTime
  excerpt   String
  content   String   @db.Text
  imageUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  reactions    Reaction[]
  commentaires Commentaire[]

  @@index([slug])
}

// Réaction (like) d'un utilisateur sur un signalement OU une actualité.
// Une seule des deux cibles (signalementId / actualiteId) est renseignée.
model Reaction {
  id String @id @default(uuid()) @db.Uuid

  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  signalementId String?             @db.Uuid
  signalement   SignalementCitoyen? @relation(fields: [signalementId], references: [id], onDelete: Cascade)

  actualiteId String?    @db.Uuid
  actualite   Actualite? @relation(fields: [actualiteId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  // Idempotence du toggle : un utilisateur ne peut liker qu'une fois une cible donnée.
  @@unique([userId, signalementId])
  @@unique([userId, actualiteId])
  @@index([signalementId])
  @@index([actualiteId])
  @@map("reactions")
}

// Commentaire d'un utilisateur sur un signalement OU une actualité.
// Une seule des deux cibles (signalementId / actualiteId) est renseignée.
model Commentaire {
  id      String @id @default(uuid()) @db.Uuid
  contenu String @db.Text

  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  signalementId String?             @db.Uuid
  signalement   SignalementCitoyen? @relation(fields: [signalementId], references: [id], onDelete: Cascade)

  actualiteId String?    @db.Uuid
  actualite   Actualite? @relation(fields: [actualiteId], references: [id], onDelete: Cascade)

  masque Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([signalementId])
  @@index([actualiteId])
  @@map("commentaires")
}

// État de gamification d'un utilisateur : points cumulés et niveau dérivé.
// Une seule ligne par utilisateur (relation 1-1 via userId unique).
model UserGamification {
  userId String @db.Uuid @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  points Int @default(0)
  niveau Int @default(1)

  updatedAt DateTime @updatedAt

  @@map("user_gamification")
}

// Historique des attributions de points (journal des transactions).
model PointTransaction {
  id String @id @default(uuid()) @db.Uuid

  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  points Int
  raison String

  createdAt DateTime @default(now())

  @@index([userId])
  @@map("point_transactions")
}
